{
  "name": "chiroclickehr-desktop",
  "version": "2.0.0",
  "description": "ChiroClickEHR Desktop - Standalone EHR for Chiropractors",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "no.chiroclickehr.desktop",
    "productName": "ChiroClickEHR",
    "directories": {
      "output": "../release"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "asarUnpack": [
      "node_modules/electron-store/**"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "extraResources": [
      {
        "from": "../backend/src",
        "to": "backend/src",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!.cache/**"
        ]
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
