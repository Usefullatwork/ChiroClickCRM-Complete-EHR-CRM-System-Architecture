{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Bash(cd backend && npm test*)",
      "Bash(cd backend && npx jest*)",
      "Bash(cd frontend && npm test*)",
      "Bash(cd frontend && npm run build*)",
      "Bash(cd frontend && npx vitest*)",
      "Bash(npm run lint*)",
      "Bash(cd backend && npm run lint*)",
      "Bash(cd frontend && npm run lint*)",
      "Bash(npx playwright test*)",
      "Bash(cd e2e && npx playwright*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(pwd*)",
      "Bash(npm list*)",
      "Bash(npm audit*)",
      "Bash(npm run swagger*)",
      "Bash(cd backend && npm run swagger*)",
      "Bash(cd backend && npm start*)",
      "Bash(cd backend && npm run dev*)",
      "Bash(cd frontend && npm run dev*)",
      "Bash(curl *)",
      "Bash(sleep *)",
      "Bash(rm -f *)",
      "Bash(rm -rf data/pglite*)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(du *)",
      "Bash(bash scripts/*)",
      "Bash(chmod *)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(date *)",
      "Bash(wc *)",
      "Bash(npx prettier *)",
      "Bash(npm run *)",
      "Bash(npx vitest *)",
      "Bash(npx playwright *)",
      "Bash(node -e *)",
      "Bash(find *)",
      "Bash(grep *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(git clean*)",
      "Bash(git checkout . *)",
      "Bash(drop database*)",
      "Bash(DROP DATABASE*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "BRANCH=$(git branch --show-current 2>/dev/null); if [ \"$BRANCH\" = \"main\" ] && [ \"$CLAUDE_TOOL_INPUT_FILE_PATH\" != \"CLAUDE.md\" ]; then echo '{\"decision\":\"block\",\"reason\":\"Cannot edit directly on main branch. Create a feature branch first: git checkout -b feature/your-change\"}'; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT_FILE_PATH\" | grep -qE '\\.(js|jsx|ts|tsx)$'; then npx prettier --write \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null; fi",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT_FILE_PATH\" | grep -qE '\\.(js|jsx|ts|tsx)$'; then HITS=$(grep -n 'console\\.log' \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null); if [ -n \"$HITS\" ]; then echo \"{\\\"systemMessage\\\":\\\"HEALTHCARE VIOLATION: console.log detected. PHI leak risk under Normen 5.4.4 and GDPR Art.9. Lines: $(echo $HITS | head -3)\\\"}\"; fi; fi",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
