{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "name",
    "description",
    "domain",
    "complexity",
    "model",
    "tools",
    "tags",
    "version"
  ],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string", "minLength": 20 },
    "domain": {
      "enum": [
        "development",
        "security",
        "trading",
        "data-ml",
        "devops",
        "seo",
        "product",
        "project-mgmt",
        "writing",
        "orchestration",
        "domain-specific",
        "meta"
      ]
    },
    "complexity": {
      "enum": ["basic", "intermediate", "advanced", "expert"]
    },
    "model": {
      "enum": ["haiku", "sonnet", "opus"]
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "version": { "type": "string" },
    "color": {
      "type": "string",
      "enum": [
        "green",
        "blue",
        "magenta",
        "cyan",
        "yellow",
        "purple",
        "red",
        "white"
      ],
      "description": "CLI output color for curated agents"
    },
    "maxTurns": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Maximum agentic turns before agent stops"
    },
    "permissionMode": {
      "type": "string",
      "enum": [
        "default",
        "acceptEdits",
        "dontAsk",
        "bypassPermissions",
        "plan"
      ],
      "description": "Permission mode for the agent"
    },
    "memory": {
      "type": "string",
      "enum": ["user", "project", "local"],
      "description": "Persistent memory scope"
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Skill names to preload into agent context"
    },
    "effort": {
      "type": "string",
      "enum": ["low", "medium", "high", "max"],
      "description": "Effort level override"
    },
    "isolation": {
      "type": "string",
      "enum": ["worktree"],
      "description": "Run in isolated git worktree"
    }
  }
}
