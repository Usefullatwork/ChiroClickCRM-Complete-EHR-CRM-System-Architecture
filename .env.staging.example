# =============================================================================
# ChiroClickEHR — Staging Environment
# =============================================================================
# Copy to .env.staging and fill in all values.
#   docker compose -f docker-compose.production.yml --env-file .env.staging up -d
#
# Staging uses the same compose file as production but with lower limits and
# a separate domain. Safe for testing deployments, migrations, and integrations.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=staging
PORT=3000
API_VERSION=v1
DESKTOP_MODE=false

# -----------------------------------------------------------------------------
# Deployment Tags (pin to specific SHA tags for staging)
# -----------------------------------------------------------------------------
BACKEND_TAG=latest
FRONTEND_TAG=latest

# -----------------------------------------------------------------------------
# Deployment Target
# -----------------------------------------------------------------------------
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_SSH_KEY_PATH=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_ENGINE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=chiroclickcrm_staging
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_staging_db_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
CACHE_ENGINE=redis
REDIS_PASSWORD=CHANGE_ME_staging_redis_password
REDIS_DB=0

# -----------------------------------------------------------------------------
# Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Use DIFFERENT keys than production.
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_staging_only
ENCRYPTION_ALGORITHM=aes-256-cbc
KEY_ROTATION_DAYS=90

# -----------------------------------------------------------------------------
# Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use DIFFERENT secrets than production.
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_staging_only
JWT_EXPIRES_IN=24h
SESSION_SECRET=CHANGE_ME_staging_only

# -----------------------------------------------------------------------------
# Clerk (use a separate Clerk dev/staging instance)
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -----------------------------------------------------------------------------
# CORS — staging domain
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://staging.chiroclickehr.no

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@chiroclickehr.no

# -----------------------------------------------------------------------------
# AI Integration
# -----------------------------------------------------------------------------
AI_ENABLED=true
AI_MODEL=chiro-no-sft-dpo-v6
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
AI_TIMEOUT=35000
GUARDRAILS_ENABLED=true
RAG_ENABLED=false

# -----------------------------------------------------------------------------
# Claude API (test with low budgets on staging)
# -----------------------------------------------------------------------------
CLAUDE_FALLBACK_MODE=disabled
CLAUDE_API_KEY=
CLAUDE_DAILY_BUDGET_USD=2
CLAUDE_MONTHLY_BUDGET_USD=20

# -----------------------------------------------------------------------------
# Email (use a test SMTP service like Mailtrap for staging)
# -----------------------------------------------------------------------------
ENABLE_EMAIL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ChiroClickEHR Staging
SMTP_FROM_EMAIL=noreply-staging@chiroclickehr.no

# -----------------------------------------------------------------------------
# SMS (disabled on staging to prevent accidental sends)
# -----------------------------------------------------------------------------
ENABLE_SMS=false
PHONE_BRIDGE_METHOD=manual
PHONE_DEVICE_ID=
PHONE_API_URL=
TELNYX_API_KEY=

# -----------------------------------------------------------------------------
# Calendar Integrations
# -----------------------------------------------------------------------------
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Backup (shorter retention for staging, no S3)
# -----------------------------------------------------------------------------
BACKUP_ENCRYPTION_KEY=CHANGE_ME_staging_backup_key
RETENTION_DAYS=30
S3_BUCKET=

# -----------------------------------------------------------------------------
# Logging (verbose for debugging on staging)
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# -----------------------------------------------------------------------------
# Feature Flags (enable more features for testing)
# -----------------------------------------------------------------------------
FEATURE_SMS_ENABLED=false
FEATURE_EMAIL_ENABLED=false
FEATURE_AUTO_RECALLS=true
FEATURE_ONLINE_BOOKING=true

# -----------------------------------------------------------------------------
# Norwegian Compliance
# -----------------------------------------------------------------------------
TIMEZONE=Europe/Oslo
DEFAULT_LANGUAGE=NO
GDPR_DATA_RETENTION_YEARS=10

# -----------------------------------------------------------------------------
# Rate Limiting (lower for staging to catch issues early)
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50
