# =============================================================================
# ChiroClickEHR — Production Environment
# =============================================================================
# Copy to .env.production and fill in all values before deploying.
#   docker compose -f docker-compose.production.yml --env-file .env.production up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
API_VERSION=v1
DESKTOP_MODE=false

# -----------------------------------------------------------------------------
# Deployment Tags (GHCR image versions)
# -----------------------------------------------------------------------------
BACKEND_TAG=latest
FRONTEND_TAG=latest

# -----------------------------------------------------------------------------
# Deployment Target (for CI/CD scripts)
# -----------------------------------------------------------------------------
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_SSH_KEY_PATH=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_ENGINE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=chiroclickcrm
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_use_a_strong_random_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
CACHE_ENGINE=redis
REDIS_PASSWORD=CHANGE_ME_use_a_strong_random_password
REDIS_DB=0

# -----------------------------------------------------------------------------
# Encryption (CRITICAL — protects fodselsnummer and health data)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_generate_with_command_above
ENCRYPTION_ALGORITHM=aes-256-cbc
KEY_ROTATION_DAYS=90

# -----------------------------------------------------------------------------
# Authentication
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Generate SESSION_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_generate_with_command_above
JWT_EXPIRES_IN=24h
SESSION_SECRET=CHANGE_ME_generate_with_command_above

# -----------------------------------------------------------------------------
# Clerk (cloud authentication provider)
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://chiroclickehr.no

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@chiroclickehr.no

# -----------------------------------------------------------------------------
# AI Integration (Ollama runs natively on host for GPU access)
# -----------------------------------------------------------------------------
AI_ENABLED=true
AI_MODEL=chiro-no-sft-dpo-v6
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
AI_TIMEOUT=35000
GUARDRAILS_ENABLED=true
RAG_ENABLED=false

# -----------------------------------------------------------------------------
# Claude API (optional cloud AI fallback)
# Modes: disabled, fallback, preferred, claude_only
# -----------------------------------------------------------------------------
CLAUDE_FALLBACK_MODE=disabled
CLAUDE_API_KEY=
CLAUDE_DAILY_BUDGET_USD=10
CLAUDE_MONTHLY_BUDGET_USD=200

# -----------------------------------------------------------------------------
# Email (nodemailer)
# -----------------------------------------------------------------------------
ENABLE_EMAIL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ChiroClickEHR
SMTP_FROM_EMAIL=noreply@chiroclickehr.no

# -----------------------------------------------------------------------------
# SMS
# -----------------------------------------------------------------------------
ENABLE_SMS=false
PHONE_BRIDGE_METHOD=manual
PHONE_DEVICE_ID=
PHONE_API_URL=
TELNYX_API_KEY=

# -----------------------------------------------------------------------------
# Calendar Integrations (optional)
# -----------------------------------------------------------------------------
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_a_strong_key
RETENTION_DAYS=3650
S3_BUCKET=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_SMS_ENABLED=false
FEATURE_EMAIL_ENABLED=false
FEATURE_AUTO_RECALLS=true
FEATURE_ONLINE_BOOKING=false

# -----------------------------------------------------------------------------
# Norwegian Compliance
# -----------------------------------------------------------------------------
TIMEZONE=Europe/Oslo
DEFAULT_LANGUAGE=NO
GDPR_DATA_RETENTION_YEARS=10

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
